# PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/digital_medical"

# JWT
JWT_SECRET="change-this-to-a-secure-random-string"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:5173"

# Cloudflare R2 Storage
# Account ID: dash.cloudflare.com → Overview → right sidebar "Account ID"
R2_ACCOUNT_ID=""
# API Token credentials: R2 → Manage R2 API Tokens → Create API Token
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
# Exact bucket name you created in R2
R2_BUCKET_NAME="digital-medical"
# Public URL: R2 → your bucket → Settings → Public Access → copy the r2.dev URL
# Or your custom domain, e.g. https://cdn.yoursite.com
R2_PUBLIC_URL=""

# WhatsApp (innamico / BuzWap gateway)
WA_USER=""
WA_PASS=""
WA_SENDER=""

# SMTP Email
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Digital Medical <noreply@digitalmedical.in>"
